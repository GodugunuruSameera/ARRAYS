CODE:
import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        int T = sc.nextInt();

        while (T-- > 0) {
            int N = sc.nextInt();

            int[] divisors = new int[1000];
            int count = 0;

            for (int i = 1; i <= N; i++) {
                if (N % i == 0) {
                    divisors[count] = i;
                    count++;
                }
            }

            int evenCount = 0;
            int oddCount = 0;

            for (int i = 0; i < count; i++) {
                if (divisors[i] % 2 == 0)
                    evenCount++;
                else
                    oddCount++;
            }

            if (evenCount == oddCount)
                System.out.println(1);
            else
                System.out.println(0);
        }

        sc.close();
    }
}
